# ─── Cloudflare Worker secrets ────────────────────────────────────────────────
# Set these with: wrangler secret put <KEY>
# Never commit real values to git.

# JSearch API (via RapidAPI) — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key_here
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# Admin secret — used to protect POST /api/jobs/refresh
ADMIN_SECRET=your_long_random_secret_here

# ─── wrangler.toml vars (not secrets, safe to commit) ─────────────────────────
ENVIRONMENT=production

# ─── Next.js frontend (.env.local) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://linkgh.com/api
